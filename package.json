{
  "name": "t3kit",
  "version": "10.0.0",
  "description": "Base theme for t3kit project. A TYPO3 website starterkit.",
  "license": "GPL-2.0",
  "authors": "t3kit Community",
  "repository": "t3kit/t3kit",
  "scripts": {
    "lint-js": "standard -v 'theme/src/js/**/*.js' | snazzy",
    "lint-config": "standard -v 'theme/config/**/*.js' | snazzy",
    "lint-css": "stylelint 'theme/src/styles/**/*.{css,scss}' --cache --cache-location .cache/.stylelintcache",
    "lint-editorconfig": "eclint check '**/*.{sh,yml,yaml,json,xml,xlf,html}' '!Resources/Public/**/*' '!theme/.tmp/**/*'",
    "lint-all": "npm-run-all --parallel lint-config lint-js lint-config lint-editorconfig",
    "composer-test": "composer test",
    "test": "npm-run-all --parallel lint-all composer-test",
    "favicons": "gulp -f theme/config/gulpfile.js favicons",
    "filetype": "gulp -f theme/config/gulpfile.js filetype",
    "icons": "gulp -f theme/config/gulpfile.js icons",
    "start": "node theme/config/start.js",
    "dev": "node theme/config/build.js",
    "prod": "NODE_ENV=production node theme/config/build.js",
    "build": "npm-run-all --parallel dev prod"
  },
  "dependencies": {
    "bootstrap": "v5.0.0-alpha2",
    "bootstrap-icons": "1.1.0",
    "file-icon-vectors": "1.0.0",
    "simplelightbox": "2.7.0",
    "swiper": "6.4.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^11.0.0",
    "app-root-path": "~3.0.0",
    "autoprefixer": "~10.1.0",
    "boxen": "~4.2.0",
    "browserslist": "~4.15.0",
    "chalk": "^4.1.0",
    "chokidar": "^3.4.3",
    "cpy": "~8.1.1",
    "css-tree": "^1.1.2",
    "cssnano": "~4.1.10",
    "cssom": "^0.4.4",
    "del": "~6.0.0",
    "eclint": "~2.8.1",
    "filesize": "^6.1.0",
    "fs-extra": "~9.0.1",
    "gaze": "^1.1.3",
    "git-rev-sync": "~3.0.1",
    "glob": "^7.1.6",
    "globby": "^11.0.1",
    "gulp": "~4.0.2",
    "gulp-brotli": "~3.0.0",
    "gulp-gzip": "~1.4.2",
    "gulp-if": "~3.0.0",
    "gulp-postcss": "~9.0.0",
    "gulp-real-favicon": "~0.3.2",
    "gulp-rev": "~9.0.0",
    "gulp-rev-delete-original": "~0.2.3",
    "gulp-sass": "~4.1.0",
    "gulp-size": "~3.0.0",
    "gulp-sourcemaps": "~3.0.0",
    "hasha": "^5.2.2",
    "husky": "~4.3.5",
    "moment": "^2.29.1",
    "npm-run-all": "~4.1.5",
    "p-each-series": "^2.2.0",
    "p-map-series": "^2.1.0",
    "p-series": "^2.1.0",
    "postcss": "^8.2.1",
    "postcss-import": "~13.0.0",
    "postcss-load-config": "^3.0.0",
    "rollup": "~2.34.2",
    "rollup-plugin-iife": "^0.3.1",
    "rollup-plugin-sizes": "~1.0.3",
    "rollup-plugin-terser": "~7.0.2",
    "sass": "~1.30.0",
    "snazzy": "^9.0.0",
    "standard": "~16.0.3",
    "stylelint": "~13.8.0",
    "stylelint-config-standard": "~20.0.0"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=14.15.1"
  },
  "browserslist": [
    "> 1.6% and last 2 versions",
    "IOS >= 13 and > 0.5%",
    "Safari >= 13"
  ],
  "standard": {
    "ignore": [
      "vendor/",
      "dist/",
      "Resources/Public/"
    ]
  },
  "stylelint": {
    "extends": "stylelint-config-standard",
    "rules": {
      "selector-pseudo-element-colon-notation": "single",
      "no-descending-specificity": null,
      "comment-empty-line-before": null,
      "at-rule-no-unknown": null
    },
    "ignoreFiles": [
      "**/vendor/**/*.css",
      "Resources/Public/"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm test"
    }
  }
}
