{
  "name": "t3kit",
  "version": "10.0.0",
  "description": "Base theme for t3kit project. A TYPO3 website starterkit.",
  "license": "GPL-2.0",
  "authors": "t3kit Community",
  "repository": "t3kit/t3kit",
  "scripts": {
    "lint-css": "stylelint 'theme/src/css/**/*.css' --cache --cache-location .cache/.stylelintcache",
    "lint-scss": "stylelint 'theme/src/scss/**/*.scss' --cache --cache-location .cache/.stylelintcache",
    "lint-js": "standard -v 'theme/src/js/**/*.js' | snazzy",
    "lint-config": "standard -v 'theme/config/**/*.js' | snazzy",
    "lint-editorconfig": "editorconfig-checker -exclude LICENSE.txt",
    "lint-all": "npm-run-all --parallel lint-css lint-scss lint-js lint-config lint-editorconfig",
    "composer-test": "composer test",
    "test": "npm-run-all --parallel lint-all composer-test",
    "favicons": "gulp -f theme/config/gulpfile.js favicons",
    "filetype": "gulp -f theme/config/gulpfile.js filetype",
    "icons": "gulp -f theme/config/gulpfile.js icons",
    "start": "node theme/config/start.js",
    "dev": "node theme/config/build.js",
    "prod": "NODE_ENV=production node theme/config/build.js",
    "build": "npm-run-all --parallel dev prod"
  },
  "dependencies": {
    "bootstrap": "v5.0.0-alpha2",
    "bootstrap-icons": "1.1.0",
    "file-icon-vectors": "1.0.0",
    "simplelightbox": "2.7.0",
    "swiper": "6.4.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "~11.0.0",
    "app-root-path": "~3.0.0",
    "boxen": "~4.2.0",
    "browserslist": "~4.15.0",
    "chalk": "~4.1.0",
    "chokidar": "~3.4.3",
    "cpy": "~8.1.1",
    "cssnano": "~4.1.10",
    "cssom": "~0.4.4",
    "del": "~6.0.0",
    "editorconfig-checker": "~3.3.0",
    "filesize": "~6.1.0",
    "fs-extra": "~9.0.1",
    "git-rev-sync": "~3.0.1",
    "globby": "~11.0.1",
    "hasha": "~5.2.2",
    "husky": "~4.3.5",
    "moment": "~2.29.1",
    "npm-run-all": "~4.1.5",
    "p-each-series": "~2.2.0",
    "postcss": "~8.2.1",
    "postcss-import": "~13.0.0",
    "rollup": "~2.34.2",
    "rollup-plugin-sizes": "~1.0.3",
    "rollup-plugin-terser": "~7.0.2",
    "sass": "~1.30.0",
    "snazzy": "~9.0.0",
    "standard": "~16.0.3",
    "stylelint": "~13.8.0",
    "stylelint-config-standard": "~20.0.0"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=14.15.1"
  },
  "browserslist": [
    "> 1.6% and last 2 versions",
    "IOS >= 13 and > 0.5%",
    "Safari >= 13"
  ],
  "standard": {
    "ignore": [
      "vendor/",
      "dist/",
      "Resources/Public/"
    ]
  },
  "stylelint": {
    "extends": "stylelint-config-standard",
    "rules": {
      "selector-pseudo-element-colon-notation": "single",
      "no-descending-specificity": null,
      "comment-empty-line-before": null,
      "at-rule-no-unknown": null
    },
    "ignoreFiles": [
      "**/vendor/**/*.css",
      "Resources/Public/"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm test"
    }
  }
}
