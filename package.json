{
  "name": "t3kit",
  "version": "10.0.0",
  "description": "Base theme for t3kit project. A TYPO3 website starterkit.",
  "license": "GPL-2.0",
  "authors": "t3kit Community",
  "repository": "t3kit/t3kit",
  "scripts": {
    "lint-js": "standard -v 'theme/src/js/**/*.js' | snazzy",
    "lint-config": "standard -v 'theme/config/**/*.js' | snazzy",
    "lint-css": "stylelint 'theme/src/styles/**/*.{css,scss}' --cache --cache-location .cache/.stylelintcache",
    "lint-editorconfig": "eclint check '**/*.{sh,yml,yaml,json,xml,xlf,html}' '!Resources/Public/**/*' '!theme/.tmp/**/*'",
    "lint-fix": "stylelint 'theme/src/styles/**/*.{css,scss}' --fix",
    "test": "npm-run-all --parallel lint-config lint-editorconfig",
    "composer": "composer test",
    "githook": "npm-run-all --parallel test composer",
    "favicons": "gulp -f theme/config/gulpfile.js favicons",
    "filetype": "gulp -f theme/config/gulpfile.js filetype",
    "icons": "gulp -f theme/config/gulpfile.js icons",
    "dev": "gulp -f theme/config/gulpfile.js build",
    "prod": "NODE_ENV=production gulp -f theme/config/gulpfile.js build",
    "build": "npm-run-all --parallel dev prod",
    "start": "gulp -f theme/config/gulpfile.js",
    "testt": "gulp -f theme/config/gulpfile.js testt",
    "testtp": "NODE_ENV=production gulp -f theme/config/gulpfile.js testt"
  },
  "dependencies": {
    "bootstrap": "5.0.0-alpha2",
    "bootstrap-icons": "1.1.0",
    "file-icon-vectors": "1.0.0",
    "simplelightbox": "2.7.0",
    "swiper": "6.3.5"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^11.0.0",
    "app-root-path": "~3.0.0",
    "autoprefixer": "~10.1.0",
    "boxen": "~4.2.0",
    "browserslist": "~4.15.0",
    "chalk": "~4.1.0",
    "cpy": "~8.1.1",
    "cssnano": "~4.1.10",
    "del": "~6.0.0",
    "eclint": "~2.8.1",
    "fs-extra": "~9.0.1",
    "git-rev-sync": "~3.0.1",
    "gulp": "~4.0.2",
    "gulp-brotli": "~3.0.0",
    "gulp-gzip": "~1.4.2",
    "gulp-if": "~3.0.0",
    "gulp-postcss": "~9.0.0",
    "gulp-real-favicon": "~0.3.2",
    "gulp-rev": "~9.0.0",
    "gulp-rev-delete-original": "~0.2.3",
    "gulp-sass": "~4.1.0",
    "gulp-size": "~3.0.0",
    "gulp-sourcemaps": "~3.0.0",
    "husky": "~4.3.5",
    "npm-run-all": "~4.1.5",
    "postcss": "~8.2.0",
    "postcss-import": "~13.0.0",
    "rollup": "~2.34.2",
    "rollup-plugin-sizes": "~1.0.3",
    "rollup-plugin-terser": "~7.0.2",
    "sass": "~1.30.0",
    "standard": "~16.0.3",
    "stylelint": "~13.8.0",
    "stylelint-config-standard": "~20.0.0"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=12.16.0"
  },
  "browserslist": [
    "> 1.6% and last 2 versions",
    "IOS >= 13 and > 0.5%",
    "Safari >= 13"
  ],
  "standard": {
    "ignore": [
      "dist/",
      "Resources/Public/"
    ]
  },
  "stylelint": {
    "extends": "stylelint-config-standard",
    "rules": {
      "selector-pseudo-element-colon-notation": "single",
      "no-descending-specificity": null,
      "comment-empty-line-before": null,
      "at-rule-no-unknown": null
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run githook"
    }
  },
  "t3kit": {
    "theme-name": "t3kit",
    "typo3-site-config-dir": "t3kit",
    "favicon-master-picture": "favicon.svg",
    "proxy-host": "t3kit10.t3.localhost"
  }
}
